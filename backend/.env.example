# OrbitOps Environment Variables

# DATABASE_URL can be your local PostgreSQL connection string or your Supabase connection string.
# Supabase provides this in Project Settings -> Database -> Connection string -> URI.
# e.g., DATABASE_URL=postgresql://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:yesha@localhost:5432/orbitops

# Local fallback parameters (used if DATABASE_URL is not provided)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yesha

# Redis configurations (optional / fallback default is localhost)
REDIS_URL=redis://localhost:6379/0
